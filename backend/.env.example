# ChatMerge backend environment variables
# Copy to .env for local development.
#
# NOTE: API keys (OpenAI, Anthropic, Gemini, Pinecone) are NOT server-side env vars.
# Users enter them in the browser Settings modal — they are stored in localStorage and
# sent as request headers (x-openai-key, x-anthropic-key, x-google-key, x-pinecone-key).
# The server never stores them.

# Database (optional — defaults to SQLite for local dev)
# PostgreSQL for production (Railway PostgreSQL plugin injects DATABASE_URL automatically):
# DATABASE_URL=postgresql://user:pass@host/dbname

# CORS (optional — defaults to allow all origins for local development)
# Set to your Railway URL in production:
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# Server configuration (local development only)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
