# API Keys for the multi-provider AI chat backend
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (required for OpenAI provider and RAG embeddings)
OPENAI_API_KEY=sk-...

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API Key
GOOGLE_API_KEY=...

# Pinecone API Key (optional - enables RAG retrieval for merged chats)
# Get your key at https://app.pinecone.io/
PINECONE_API_KEY=...

# Database configuration
# Local development (default - no setup needed):
# DATABASE_URL=sqlite+aiosqlite:///./chat_app.db
#
# PostgreSQL for production (Railway PostgreSQL plugin, Neon, Supabase):
# DATABASE_URL=postgresql://user:pass@host/dbname
# (The app automatically converts to asyncpg dialect)

# CORS (optional - defaults to allow all for development)
# Production: set to your Railway URL, comma-separated
# ALLOWED_ORIGINS=https://chatmerge.up.railway.app

# Server configuration (local development only)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
